diff --git a/open-sse/utils/cursorReasoningMarkdown.js b/open-sse/utils/cursorReasoningMarkdown.js
new file mode 100644
index 0000000..d4e5f6a
--- /dev/null
+++ b/open-sse/utils/cursorReasoningMarkdown.js
@@ -0,0 +1,82 @@
+/** Collapsible markdown block for BYOK clients that ignore reasoning_content (Cursor Thought panel). */
+
+export const REASONING_MARKDOWN_OPEN = "<details>\n<summary>Thinking…</summary>\n\n";
+export const REASONING_MARKDOWN_CLOSE = "\n\n</details>\n\n";
+export const REASONING_MARKDOWN_END = "\n\n</details>";
+
+/**
+ * @returns {boolean}
+ */
+export function isCursorReasoningMarkdownFallbackEnabled() {
+  return process.env.CURSOR_REASONING_MARKDOWN_FALLBACK === "1";
+}
+
+/**
+ * Wrap reasoning + optional answer text as a collapsible markdown block.
+ * @param {string} reasoning
+ * @param {string} [content]
+ * @returns {string}
+ */
+export function wrapReasoningAsMarkdown(reasoning, content = "") {
+  const trimmed = (reasoning || "").trim();
+  if (!trimmed) return content || "";
+  const answer = content || "";
+  if (answer) {
+    return `${REASONING_MARKDOWN_OPEN}${trimmed}${REASONING_MARKDOWN_CLOSE}${answer}`;
+  }
+  return `${REASONING_MARKDOWN_OPEN}${trimmed}${REASONING_MARKDOWN_END}`;
+}
+
+/**
+ * Mirrors streaming reasoning deltas into visible markdown content chunks.
+ */
+export class ReasoningMarkdownStreamMirror {
+  constructor() {
+    /** @type {boolean} */
+    this.open = false;
+    /** @type {boolean} */
+    this.closed = false;
+  }
+
+  /**
+   * @param {string} deltaReasoning
+   * @returns {string|null}
+   */
+  mirrorReasoningDelta(deltaReasoning) {
+    if (!deltaReasoning) return null;
+    let out = "";
+    if (!this.open) {
+      out += REASONING_MARKDOWN_OPEN;
+      this.open = true;
+    }
+    out += deltaReasoning;
+    return out;
+  }
+
+  /**
+   * Prefix to emit before the first visible answer chunk.
+   * @returns {string|null}
+   */
+  closeBeforeContent() {
+    if (!this.open || this.closed) return null;
+    this.closed = true;
+    return REASONING_MARKDOWN_CLOSE;
+  }
+
+  /**
+   * Close an open block when the turn ends with reasoning/tool calls only.
+   * @returns {string|null}
+   */
+  finalize() {
+    if (!this.open || this.closed) return null;
+    this.closed = true;
+    return REASONING_MARKDOWN_END;
+  }
+
+  /**
+   * @returns {boolean}
+   */
+  isOpen() {
+    return this.open && !this.closed;
+  }
+}
