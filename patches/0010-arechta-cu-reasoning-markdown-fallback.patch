+
+describe("cursorReasoningMarkdown fallback", () => {
+  it("wraps reasoning and content in a collapsible details block", () => {
+    const wrapped = wrapReasoningAsMarkdown("plan step", "Hello!");
+    expect(wrapped).toContain("<details>");
+    expect(wrapped).toContain("<summary>Thinking…</summary>");
+    expect(wrapped).toContain("plan step");
+    expect(wrapped).toContain("</details>");
+    expect(wrapped).toContain("Hello!");
+  });
+
+  it("mirrors streaming reasoning into content when env enabled", async () => {
+    const prev = process.env.CURSOR_REASONING_MARKDOWN_FALLBACK;
+    process.env.CURSOR_REASONING_MARKDOWN_FALLBACK = "1";
+    try {
+      const executor = new CursorExecutor();
+      const buffer = cursorResponseFrames([
+        { thinking: "The user asked to load" },
+        { thinking: " the skill.\n</think><｜final｜>**loaded**." },
+      ]);
+
+      const response = await executor.transformProtobufToSSE(buffer, "cu/default", {
+        messages: [{ role: "user", content: "load skill" }],
+      });
+      const deltas = await collectSseDeltas(response);
+      const content = deltas.map((delta) => delta.content || "").join("");
+      const reasoning = deltas.map((delta) => delta.reasoning_content || "").join("");
+
+      expect(content).toContain("<details>");
+      expect(content).toContain("The user asked to load the skill");
+      expect(content).toContain("**loaded**.");
+      expect(reasoning).toContain("The user asked to load the skill");
+    } finally {
+      if (prev === undefined) delete process.env.CURSOR_REASONING_MARKDOWN_FALLBACK;
+      else process.env.CURSOR_REASONING_MARKDOWN_FALLBACK = prev;
+    }
+  });
+
+  it("closes details before tool calls when only reasoning precedes tools", async () => {
+    const prev = process.env.CURSOR_REASONING_MARKDOWN_FALLBACK;
+    process.env.CURSOR_REASONING_MARKDOWN_FALLBACK = "1";
+    try {
+      const mirror = new ReasoningMarkdownStreamMirror();
+      expect(mirror.mirrorReasoningDelta("plan")).toContain("<details>");
+      expect(mirror.closeBeforeContent()).toContain("</details>");
+      expect(mirror.finalize()).toBeNull();
+      expect(mirror.isOpen()).toBe(false);
+
+      const executor = new CursorExecutor();
+      const buffer = cursorResponseFrames([
+        { thinking: "Need glob\n</think>" },
+        {
+          thinking: [
+            "<｜tool▁calls▁begin｜><｜tool▁call▁begin｜>",
+            "Glob",
+            "<｜tool▁sep｜>glob_pattern **/*",
+            "<｜tool▁call▁end｜><｜tool▁calls▁end｜>",
+          ].join("\n"),
+        },
+      ]);
+
+      const response = await executor.transformProtobufToSSE(buffer, "cu/default", {
+        messages: [{ role: "user", content: "load skill" }],
+      });
+      const deltas = await collectSseDeltas(response);
+      const content = deltas.map((delta) => delta.content || "").join("");
+
+      expect(content).toContain("<details>");
+      expect(content).toContain("Need glob");
+      expect(content).toContain("</details>");
+      expect(content).not.toMatch(/<details>[\s\S]*<details>/);
+    } finally {
+      if (prev === undefined) delete process.env.CURSOR_REASONING_MARKDOWN_FALLBACK;
+      else process.env.CURSOR_REASONING_MARKDOWN_FALLBACK = prev;
+    }
+  });
+
+  it("wraps non-streaming JSON message content when env enabled", async () => {
+    const prev = process.env.CURSOR_REASONING_MARKDOWN_FALLBACK;
+    process.env.CURSOR_REASONING_MARKDOWN_FALLBACK = "1";
+    try {
+      const executor = new CursorExecutor();
+      const buffer = cursorResponseFrame({
+        thinking: "internal plan</think>Hello!",
+      });
+
+      const response = await executor.transformProtobufToJSON(buffer, "cu/default", {
+        messages: [{ role: "user", content: "hi" }],
+      });
+      const payload = await response.json();
+
+      expect(payload.choices[0].message.content).toContain("<details>");
+      expect(payload.choices[0].message.content).toContain("internal plan");
+      expect(payload.choices[0].message.content).toContain("Hello!");
+      expect(payload.choices[0].message.reasoning_content).toBe("internal plan");
+    } finally {
+      if (prev === undefined) delete process.env.CURSOR_REASONING_MARKDOWN_FALLBACK;
+      else process.env.CURSOR_REASONING_MARKDOWN_FALLBACK = prev;
+    }
+  });
+});
