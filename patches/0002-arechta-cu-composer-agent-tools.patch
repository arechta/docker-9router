+++ b/open-sse/utils/cursorComposerTools.js
@@ -0,0 +1,239 @@
+/**
+ * Parse Composer / Cursor Auto control tokens embedded in assistant text.
+ * cu/default and Composer models often emit Kimi-style tool markers in thinking
+ * instead of protobuf TOOL_CALL frames.
+ */
+
+import { normalizePromotedText } from "./cursorModel.js";
+
+const TOOL_CALLS_BEGIN = "<|tool_calls_begin|>";
+const TOOL_CALLS_END = "<|tool_calls_end|>";
+const TOOL_SEP = "<|tool_sep|>";
+
+const TOOL_CALL_BLOCK_RE =
+  /<\|(?:redacted_)?tool_call_begin(?:_kimi)?\|>([\s\S]*?)<\|(?:redacted_)?tool_call_end(?:_kimi)?\|>/gi;
+
+const OUTER_CONTROL_TOKENS = [
+  TOOL_CALLS_BEGIN,
+  TOOL_CALLS_END,
+  "<|final|>",
+  "<|tool_call_begin|>",
+  "<|tool_call_end|>",
+  "<｜tool▁call▁begin｜>",
+  "<｜tool▁call▁end｜>",
+];
+
+let toolCallIdCounter = 0;
+
+function nextToolCallId() {
+  toolCallIdCounter += 1;
+  return `call_cursor_${Date.now()}_${toolCallIdCounter}`;
+}
+
+/**
+ * Extract user-visible assistant text from thinking / promoted content.
+ * @deprecated import from cursorModel.js
+ */
+export { normalizePromotedText } from "./cursorModel.js";
+
+/**
+ * Remove known Cursor control tokens from text.
+ * @param {string} text
+ * @returns {string}
+ */
+export function stripCursorControlTokens(text) {
+  let out = text;
+  for (const token of OUTER_CONTROL_TOKENS) {
+    out = out.split(token).join("");
+  }
+  out = out.replace(/<\|(?:redacted_)?tool_call_begin(?:_kimi)?\|>/gi, "");
+  out = out.replace(/<\|(?:redacted_)?tool_call_end(?:_kimi)?\|>/gi, "");
+  return out;
+}
+
+/**
+ * Parse key=value segments after tool name (Glob-style multi-arg).
+ * @param {string[]} segments
+ * @returns {Record<string, unknown>}
+ */
+function parseToolArguments(segments) {
+  const args = {};
+
+  for (const segment of segments) {
+    const trimmed = segment.trim();
+    if (!trimmed) continue;
+
+    if (trimmed.startsWith("{")) {
+      try {
+        const parsed = JSON.parse(trimmed);
+        if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
+          Object.assign(args, parsed);
+          continue;
+        }
+      } catch {
+        // fall through to key=value parsing
+      }
+    }
+
+    const spaceIdx = trimmed.indexOf(" ");
+    if (spaceIdx > 0) {
+      const key = trimmed.slice(0, spaceIdx).trim();
+      const value = trimmed.slice(spaceIdx + 1).trim();
+      if (key) args[key] = value;
+    } else if (!Object.keys(args).length) {
+      args.input = trimmed;
+    }
+  }
+
+  return args;
+}
+
+/**
+ * Parse one Composer tool-call block inner payload.
+ * @param {string} inner
+ * @returns {{ name: string, args: Record<string, unknown> } | null}
+ */
+export function parseComposerToolCallBlock(inner) {
+  if (!inner?.trim()) return null;
+
+  const parts = inner.split(TOOL_SEP).map((part) => part.trim()).filter(Boolean);
+  if (parts.length === 0) return null;
+
+  let name = parts[0];
+  let argParts = parts.slice(1);
+
+  if (name === "function" && parts.length > 1) {
+    name = parts[1];
+    argParts = parts.slice(2);
+  }
+
+  name = name.trim();
+  if (!name) return null;
+
+  return {
+    name,
+    args: parseToolArguments(argParts),
+  };
+}
+
+/**
+ * Convert parsed tool call to OpenAI chat.completion tool_calls entry.
+ * @param {{ name: string, args: Record<string, unknown> }} parsed
+ * @param {number} index
+ * @returns {{ id: string, type: "function", function: { name: string, arguments: string } }}
+ */
+export function toOpenAIToolCall(parsed) {
+  return {
+    id: nextToolCallId(),
+    type: "function",
+    function: {
+      name: parsed.name,
+      arguments: JSON.stringify(parsed.args ?? {}),
+    },
+  };
+}
+
+function shouldNormalizePromotedRaw(raw) {
+  return raw.includes("</think>")
+    || raw.includes("<|final|>")
+    || raw.includes(TOOL_CALLS_BEGIN);
+}
+
+/**
+ * Strip Composer tool markers and parse embedded tool calls from assistant text.
+ * @param {string} raw
+ * @returns {{ content: string | null, toolCalls: ReturnType<typeof toOpenAIToolCall>[] }}
+ */
+export function processComposerAssistantText(raw) {
+  if (!raw) {
+    return { content: null, toolCalls: [] };
+  }
+
+  let text = shouldNormalizePromotedRaw(raw) ? normalizePromotedText(raw) : raw;
+  const toolCalls = [];
+  const blocks = [];
+
+  TOOL_CALL_BLOCK_RE.lastIndex = 0;
+  let match = TOOL_CALL_BLOCK_RE.exec(text);
+  while (match) {
+    blocks.push({ full: match[0], inner: match[1], start: match.index });
+    match = TOOL_CALL_BLOCK_RE.exec(text);
+  }
+
+  let content = text;
+  for (let i = blocks.length - 1; i >= 0; i -= 1) {
+    const block = blocks[i];
+    const parsed = parseComposerToolCallBlock(block.inner);
+    if (parsed) {
+      toolCalls.unshift(parsed);
+    }
+    content = content.slice(0, block.start) + content.slice(block.start + block.full.length);
+  }
+
+  content = stripCursorControlTokens(content).trim();
+
+  return {
+    content: content || null,
+    toolCalls: toolCalls.map((parsed) => toOpenAIToolCall(parsed)),
+  };
+}
+
+/**
+ * Merge protobuf tool calls with text-parsed tool calls (protobuf wins).
+ * @param {string} totalContent
+ * @param {string} totalThinking
+ * @param {boolean} promoteThinking
+ * @param {Array<{ id: string, type: string, function: { name: string, arguments: string } }>} protobufToolCalls
+ * @returns {{ content: string | null, toolCalls: typeof protobufToolCalls }}
+ */
+export function finalizeAssistantOutput(totalContent, totalThinking, promoteThinking, protobufToolCalls) {
+  const rawText = totalContent
+    || (promoteThinking ? totalThinking : "")
+    || "";
+
+  const { content, toolCalls: textToolCalls } = processComposerAssistantText(rawText);
+  const toolCalls = protobufToolCalls.length > 0 ? protobufToolCalls : textToolCalls;
+
+  let finalContent = content;
+  if (!finalContent && protobufToolCalls.length > 0) {
+    finalContent = null;
+  } else if (!finalContent && totalContent) {
+    finalContent = stripCursorControlTokens(totalContent).trim() || null;
+  }
+
+  return { content: finalContent, toolCalls };
+}
+
+/**
+ * Incrementally emit clean assistant text while buffering Composer control tokens.
+ */
+export class StreamingComposerFilter {
+  /** @param {boolean} [promoteThinking] */
+  constructor(promoteThinking = false) {
+    this.rawBuffer = "";
+    this.emittedContentLength = 0;
+    this.promoteThinking = promoteThinking;
+  }
+
+  /** @param {string} text */
+  setRaw(text) {
+    this.rawBuffer = text || "";
+  }
+
+  /** @returns {string} */
+  getContentDelta() {
+    if (this.promoteThinking && !shouldNormalizePromotedRaw(this.rawBuffer)) {
+      return "";
+    }
+
+    const { content } = processComposerAssistantText(this.rawBuffer);
+    const safe = content || "";
+    const delta = safe.slice(this.emittedContentLength);
+    this.emittedContentLength = safe.length;
+    return delta;
+  }
+
+  getTextToolCalls() {
+    return processComposerAssistantText(this.rawBuffer).toolCalls;
+  }
+}
