diff --git a/open-sse/utils/cursorModel.js b/open-sse/utils/cursorModel.js
index 7910951..59121ea 100644
--- a/open-sse/utils/cursorModel.js
+++ b/open-sse/utils/cursorModel.js
@@ -116,11 +116,28 @@ export function mergeCursorAssistantRaw(totalContent, totalThinking) {
   return `${thinking}${content}`;
 }
 
+/**
+ * Streaming variant: Cursor often sends visible answer + tool wire in the thinking
+ * protobuf field. Until a closing/final marker arrives, treat it as reasoning so
+ * partial chunks do not leak into visible content.
+ * @param {string} totalContent
+ * @param {string} totalThinking
+ * @returns {string}
+ */
+export function mergeCursorAssistantRawForStreaming(totalContent, totalThinking) {
+  const content = totalContent || "";
+  const thinking = totalThinking || "";
+  if (content) return mergeCursorAssistantRaw(content, thinking);
+  if (!thinking) return "";
+  if (hasCursorThinkingMarkers(thinking)) return thinking;
+  return `${REDACTED_THINKING_BEGIN}${thinking}`;
+}
+
 function splitCursorHeuristicFallback(raw) {
   const finalIdx = raw.indexOf(FINAL_TAG);
   if (finalIdx >= 0) {
     return {
-      reasoning: raw.slice(0, finalIdx).trim(),
+      reasoning: stripThinkingBegin(raw.slice(0, finalIdx)).trim(),
       content: raw.slice(finalIdx + FINAL_TAG.length).trimStart(),
     };
   }
