diff --git a/tests/unit/cursor-composer-tools.test.js b/tests/unit/cursor-composer-tools.test.js
new file mode 100644
index 0000000..9546974
--- /dev/null
+++ b/tests/unit/cursor-composer-tools.test.js
@@ -0,0 +1,136 @@
+import { describe, it, expect } from "vitest";
+
+import {
+  normalizePromotedText,
+  parseComposerToolCallBlock,
+  processComposerAssistantText,
+  stripCursorControlTokens,
+} from "../../open-sse/utils/cursorComposerTools.js";
+import { CursorExecutor } from "../../open-sse/executors/cursor.js";
+import { encodeField, wrapConnectRPCFrame } from "../../open-sse/utils/cursorProtobuf.js";
+
+const LEN = 2;
+
+function cursorResponseFrame({ text = "", thinking = "" }) {
+  const responseFields = [];
+
+  if (text) {
+    responseFields.push(encodeField(1, LEN, text));
+  }
+
+  if (thinking) {
+    const thinkingMessage = encodeField(1, LEN, thinking);
+    responseFields.push(encodeField(25, LEN, thinkingMessage));
+  }
+
+  const response = Buffer.concat(responseFields.map((field) => Buffer.from(field)));
+  const envelope = encodeField(2, LEN, response);
+  return Buffer.from(wrapConnectRPCFrame(envelope));
+}
+
+describe("cursorComposerTools", () => {
+  it("strips <|final|> prefix from promoted text", () => {
+    expect(normalizePromotedText("<|final|>Hello")).toBe("Hello");
+  });
+
+  it("parses Kimi-style Read tool block", () => {
+    const parsed = parseComposerToolCallBlock(
+      "Read<|tool_sep|>path /home/user/SKILL.md"
+    );
+    expect(parsed).toEqual({
+      name: "Read",
+      args: { path: "/home/user/SKILL.md" },
+    });
+  });
+
+  it("parses multi-arg Glob tool block", () => {
+    const parsed = parseComposerToolCallBlock(
+      "Glob<|tool_sep|>target_directory /home/user/skills<|tool_sep|>glob_pattern */"
+    );
+    expect(parsed).toEqual({
+      name: "Glob",
+      args: {
+        target_directory: "/home/user/skills",
+        glob_pattern: "*/",
+      },
+    });
+  });
+
+  it("extracts tool_calls and clean content from composer markers", () => {
+    const raw = [
+      "internal plan</think>",
+      "<|final|>Loading skill.",
+      "<|tool_calls_begin|>",
+      "<|tool_call_begin|>Read<|tool_sep|>path /tmp/a.md<|tool_call_end|>",
+      "<|tool_calls_end|>",
+    ].join("");
+
+    const { content, toolCalls } = processComposerAssistantText(raw);
+
+    expect(content).toBe("Loading skill.");
+    expect(toolCalls).toHaveLength(1);
+    expect(toolCalls[0].function.name).toBe("Read");
+    expect(JSON.parse(toolCalls[0].function.arguments)).toEqual({ path: "/tmp/a.md" });
+    expect(stripCursorControlTokens(raw)).not.toContain("<|tool_calls_begin|>");
+  });
+});
+
+describe("CursorExecutor composer tool markers", () => {
+  it("returns OpenAI tool_calls for cu/default thinking-only agent response", async () => {
+    const executor = new CursorExecutor();
+    const thinking = [
+      "planning</think>",
+      "<|final|>Loading skill tree.",
+      "<|tool_calls_begin|>",
+      "<|tool_call_begin|>Read<|tool_sep|>path /home/user/SKILL.md<|tool_call_end|>",
+      "<|tool_calls_end|>",
+    ].join("");
+    const buffer = cursorResponseFrame({ thinking });
+
+    const response = executor.transformProtobufToJSON(buffer, "cu/default", {
+      messages: [{ role: "user", content: "load skill" }],
+      tools: [{ type: "function", function: { name: "Read", parameters: {} } }],
+    });
+    const payload = await response.json();
+
+    expect(response.status).toBe(200);
+    expect(payload.choices[0].finish_reason).toBe("tool_calls");
+    expect(payload.choices[0].message.content).toBe("Loading skill tree.");
+    expect(payload.choices[0].message.tool_calls).toHaveLength(1);
+    expect(payload.choices[0].message.tool_calls[0].function.name).toBe("Read");
+    expect(JSON.stringify(payload)).not.toContain("<|tool_calls_begin|>");
+  });
+
+  it("streams clean content and emits tool_calls for default model SSE", async () => {
+    const executor = new CursorExecutor();
+    const thinking = [
+      "private</think>",
+      "<|final|>OK",
+      "<|tool_calls_begin|>",
+      "<|tool_call_begin|>Glob<|tool_sep|>glob_pattern *.md<|tool_call_end|>",
+      "<|tool_calls_end|>",
+    ].join("");
+    const buffer = cursorResponseFrame({ thinking });
+
+    const response = executor.transformProtobufToSSE(buffer, "cu/default", {
+      messages: [{ role: "user", content: "glob" }],
+      tools: [{ type: "function", function: { name: "Glob", parameters: {} } }],
+    });
+    const text = await response.text();
+    const events = text
+      .split("\n\n")
