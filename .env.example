# ==============================================
# 9Router — Environment Configuration
# ==============================================
# cp .env.example .env
#
# Official docs: https://github.com/decolua/9router
# Docker docs:   https://github.com/decolua/9router/blob/master/DOCKER.md
#
# Consumed by: docker-compose.yml, scripts/*.sh

# --- Host / Docker compose ---

# UID/GID for container user + ./data volume ownership.
# Must match the user the container runs as. Discover on host: id <your-docker-user>
DOCKER_UID=1000
DOCKER_GID=1000

# Host bind address + port published to host (maps to container PORT)
# 127.0.0.1 = localhost only (recommended); 0.0.0.0 = all interfaces
NINE_ROUTER_BIND=127.0.0.1
NINE_ROUTER_PORT=20128

# Loopback host for scripts/healthcheck.sh on the host (not passed into container)
NINE_ROUTER_HOST=127.0.0.1

# npm package pin — no longer used (image builds from ./repository source)
# NINEROUTER_VERSION=latest

# Upstream git baseline for scripts/sync-repository.sh
# NINEROUTER_UPSTREAM_REPO=https://github.com/decolua/9router.git
# NINEROUTER_UPSTREAM_REF=master

# Local image name and tag (${IMAGE_NAME}:${IMAGE_TAG})
IMAGE_NAME=9router-local
IMAGE_TAG=latest

# --- 9Router process (container env) ---

# HTTP bind address inside container (keep 0.0.0.0; restrict via NINE_ROUTER_BIND on host)
NINE_ROUTER_HOSTNAME=0.0.0.0

NODE_ENV=production

# Security — REQUIRED for production (dashboard login + JWT)
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32
INITIAL_PASSWORD=change_me_strong_dashboard_password

# Optional endpoint-proxy secrets (generate if using advanced proxy features)
# API_KEY_SECRET=change_me_use_openssl_rand_hex_32
# MACHINE_ID_SALT=change_me_use_openssl_rand_hex_32

# Public URLs (defaults derived from PORT if unset)
# BASE_URL=http://127.0.0.1:20128
# CLOUD_URL=https://9router.com
# NEXT_PUBLIC_BASE_URL=http://127.0.0.1:20128
# NEXT_PUBLIC_CLOUD_URL=https://9router.com

# Logging / debug
ENABLE_REQUEST_LOGS=false
DEBUG=false

# Optional Headroom sidecar URL (see DOCKER.md — run headroom as separate service)
# HEADROOM_URL=http://headroom:8787
