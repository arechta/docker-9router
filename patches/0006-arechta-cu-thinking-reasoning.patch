+  const t = String(text || "").trim();
+  if (!t) return false;
+  if (hasCursorThinkingMarkers(t)) return true;
+  return PLANNING_PREFIX_RE.test(t) && !ANSWER_START_RE.test(t);
+}
+
+export function normalizePromotedText(thinking) {
+  return splitCursorThinkingSurface(thinking).content;
+}
+
+/**
+ * Whether reasoning_content should stay alongside non-empty content (Cursor split).
+ * Generic providers often duplicate thinking in content — strip those.
+ * @param {string} reasoning
+ * @param {string} content
+ * @returns {boolean}
+ */
+export function shouldPreserveReasoningWithContent(reasoning, content) {
+  const r = String(reasoning || "").trim();
+  const c = String(content || "").trim();
+  if (!r || !c) return false;
+  if (c.includes("redacted_thinking") || r.includes("redacted_thinking")) return false;
+  return !c.includes(r) && !r.includes(c);
 }
 
